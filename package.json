{
  "name": "file-path-inserter",
  "displayName": "File Path Inserter",
  "description": "Pick any file and insert its path at the cursor — relative, workspace-relative, or absolute.",
  "version": "0.1.0",
  "publisher": "aspect-tools",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "path",
    "insert path",
    "file path",
    "relative path",
    "file picker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/REPLACE_WITH_YOUR_GITHUB/vscode-relative-path"
  },
  "activationEvents": [
    "onCommand:insert-path.relative",
    "onCommand:insert-path.workspaceRelative",
    "onCommand:insert-path.absolute"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "insert-path.relative",
        "title": "Insert Path: Relative to Current File"
      },
      {
        "command": "insert-path.workspaceRelative",
        "title": "Insert Path: Relative to Workspace Root"
      },
      {
        "command": "insert-path.absolute",
        "title": "Insert Path: Absolute"
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@vscode/vsce-sign", "keytar"]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.9.3"
  }
}
